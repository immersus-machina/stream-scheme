<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <IsPackable Condition="'$(NuGetPack)' == 'true'">true</IsPackable>
    <IsPackable Condition="'$(NuGetPack)' != 'true'">false</IsPackable>

    <PackageId>StreamScheme.FSharp</PackageId>
    <Authors>Immersus Machina</Authors>
    <Description>F# native wrapper for StreamScheme — fast, typed, streaming read and write of tabular data in xlsx format.</Description>
    <PackageLicenseExpression>MIT</PackageLicenseExpression>
    <PackageProjectUrl>https://github.com/immersus-machina/stream-scheme</PackageProjectUrl>
    <RepositoryUrl>https://github.com/immersus-machina/stream-scheme.git</RepositoryUrl>
    <RepositoryType>git</RepositoryType>
    <PackageTags>fsharp;excel;xlsx;streaming;tabular;spreadsheet</PackageTags>
    <PackageReadmeFile>README.md</PackageReadmeFile>

    <GenerateDocumentationFile>true</GenerateDocumentationFile>
    <PublishRepositoryUrl>true</PublishRepositoryUrl>
    <EmbedUntrackedSources>true</EmbedUntrackedSources>
    <IncludeSymbols>true</IncludeSymbols>
    <SymbolPackageFormat>snupkg</SymbolPackageFormat>
  </PropertyGroup>

  <ItemGroup>
    <None Include="../../README.md" Pack="true" PackagePath="/" />
    <None Include="../../LICENSE" Pack="true" PackagePath="/" />
  </ItemGroup>

  <ItemGroup>
    <Compile Include="AssemblyInfo.fs" />
    <Compile Include="FieldValue.fs" />
    <Compile Include="WriteOptions.fs" />
    <Compile Include="ReadOptions.fs" />
    <Compile Include="Xlsx.fs" />
    <Compile Include="DI/Types.fs" />
    <Compile Include="DI/Contracts.fs" />
    <Compile Include="DI/Xlsx.fs" />
    <Compile Include="DI/Registration.fs" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Update="FSharp.Core" Version="10.0.100" />
    <PackageReference Include="FSharpOrDi" Version="0.4.0" PrivateAssets="all" />
    <PackageReference Include="Microsoft.SourceLink.GitHub" Version="8.0.0" PrivateAssets="all" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\StreamScheme\StreamScheme.csproj"
        PrivateAssets="compile;contentFiles;native;analyzers"
        Condition="'$(NuGetPack)' != 'true'" />
    <ProjectReference Include="..\StreamScheme\StreamScheme.csproj"
        PrivateAssets="all"
        Condition="'$(NuGetPack)' == 'true'" />
  </ItemGroup>

  <Target Name="IncludeInternalDependencies" BeforeTargets="_GetPackageFiles" Condition="'$(NuGetPack)' == 'true'">
    <ItemGroup>
      <None Include="$(OutputPath)StreamScheme.dll" Pack="true" PackagePath="lib/$(TargetFramework)" />
    </ItemGroup>
  </Target>

</Project>
